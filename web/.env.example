# VeloxFrontend — environment variables
#
# This file documents the PUBLIC env vars the frontend reads at build
# time via import.meta.env. Copy to .env for local dev. NEVER place
# secrets here: the frontend has no server-side and anything in .env
# is embedded in the built bundle.

# Base URL of the InstaEdit BFF (api.instaedit.org in production).
# In dev, leave empty to use the Vite proxy (same-origin /api/* → localhost:8000).
VITE_API_BASE_URL=https://api.instaedit.org

# Optional: dark editor iframe URL (defaults to /dark_editor_v2 via proxy in dev).
# VITE_DARK_EDITOR_URL=https://app.instaedit.org/dark_editor_v2
